PORT=4000
HOST=127.0.0.1
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/picture-republiq

# Optional. If omitted, the backend accepts the existing admin password hash.
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=replace-with-a-long-random-string

# Frontend production builds use this when the API is on a separate domain.
VITE_API_BASE_URL=https://utopian-angle.pipeops.app

# Comma-separated allowed browser origins for API calls. Use * to allow any origin.
CORS_ORIGINS=*
